# M10 — toggle between mock data (MSW) and the live Supabase backend.
# Set to "false" to activate the M10 integration; "true" or unset keeps
# everything exactly as it was in M1–M6 (MSW intercepts all API calls).
# VITE_USE_MOCKS=true

# Required when VITE_USE_MOCKS=false. For the LOCAL Supabase stack
# (supabase start), these are the fixed local values:
# VITE_SUPABASE_URL=http://127.0.0.1:54321
# VITE_SUPABASE_ANON_KEY=paste-your-local-anon-key-here

# When pointing at your HOSTED project instead, swap both values to the
# ones from your Supabase dashboard (Project Settings → API).

VITE_USE_MOCKS=false
VITE_SUPABASE_URL=http://127.0.0.1:54321
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZS1kZW1vIiwicm9sZSI6ImFub24iLCJleHAiOjE5ODM4MTI5OTZ9.CRXP1A7WOeoJeXxjNni43kdQwgnWNReilDMblYTn_I0
